<style>
  #search::placeholder {
      color: #ffc107 !important; /* Ez pontosan a Bootstrap warning sárga színe */
      opacity: 0.7; /* Érdemes egy kicsit halványabbra venni, hogy látszódjon: ez csak egy placeholder */
  }
</style>


<div class="container my-4 border border-black border-1 border-opacity-25 rounded p-2 bg-black" id="TableBody" >

  <ul class="list-group bg-black">

    <li class="list-group-item border-0 bg-black">
        <h3 class="text-center text-warning ">Logs</h3>
    </li>

  </ul>

<div class="d-flex justify-content-start align-items-center w-100 shadow-sm p-1 mb-4 bg-warning bg-opacity-25 rounded border border-1 border-black border-opacity-10 flex-grow-1">
    <div class="w-50 d-flex m-1 ">
        <form class="form-inline w-75" id="noSubmitForm">
          <input class="form-control mr-sm-2 rounded-0 rounded-start-1 border border-1 border-warning bg-black text-warning" type="search" placeholder="Search" aria-label="Search" id="search">
        </form>
        <div class="dropdown w-50 ">
            <button class="btn btn-warning dropdown-toggle rounded-0 rounded-end-1 " type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="Select search column">
              Select column
            </button>
            <div class="dropdown-menu" aria-labelledby="dropdownMenuButton" id="dropdownMenu">

            </div>

        </div>
  </div>

  </div>
<table class="table table-striped table-hover table-bordered w-100 m-0 table-dark font-monospace align-middle">
        <thead class="">
            <th scope="col">Timestamp</th>
            <th scope="col">Level</th>
            <th scope="col">Message</th>




        </thead>
        <tbody class="align-middle" id="userTableBody">
            <% logs.forEach(log=> { %>
            <% 
                // 1. Létrehozunk egy szabályrendszert a színekhez
                const logStyles = {
                    error: 'text-danger fw-bold',
                    warn: 'text-warning fw-bold',
                    info: 'text-success',
                    operation: 'text-white', // Megjegyzés: a message-nél adunk hozzá plusz fw-bolder-t
                    db: 'text-primary fw-bold',
                    auth: 'text-info',
                    validation: 'text-warning',
                    debug: 'text-secondary'
                };

                // 2. Kiválasztjuk az aktuális log szinthez tartozó stílust
                const levelStyle = logStyles[log.level] || 'text-white';
            %>

            <tr class="p-0">
                <td width="18%" class="fw-bold p-1">
                    <%= log.timestamp.toLocaleString('hu-HU') %>
                </td>
                
                <td class="<%= levelStyle %> p-1">
                    <%= log.level %>
                </td>
                
                <td class="<%= levelStyle %> p-1 <%= log.level === 'operation' ? 'fw-bolder' : '' %>">
                    <%= log.message %>
                </td>
            </tr>

            <% }); %>


        </tbody>
    </table>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel"
    aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog" role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Delete IP Record</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="deleteConfirmationText">Are you sure you want to delete this IP record?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteButton" data-deleteslug="User" data-beforeurl="/admin">Delete</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let IdToDelete = null;
    const deleteModal = document.getElementById('deleteModal');
    const confirmDeleteButton = document.getElementById('confirmDeleteButton');

    deleteModal?.addEventListener('show.bs.modal', event => {
        const button = event.relatedTarget;
        IdToDelete = button.getAttribute('data-ipid');
    });

    confirmDeleteButton?.addEventListener('click', () => {
        fetch('/admin/IpTables/delete/' + IdToDelete, {
            method: 'DELETE'
        }).then(response => {
            if (response.ok) {
                window.location.reload();
            } else {
                window.location.reload();
            }
        });
    });



});
</script>
