<div class="container my-4 border border-black border-1 border-opacity-25 rounded p-2" id="TableBody" >

  <ul class="list-group">

    <li class="list-group-item border-0">
        <h3 class="text-center">IP Ban Manager</h3>
    </li>

  </ul>

<div class="d-flex justify-content-start align-items-center w-100 shadow-sm p-1 mb-4 bg-secondary bg-opacity-25 rounded border border-1 border-black border-opacity-10 flex-grow-1">
    <div class="w-50 d-flex m-1 ">
        <form class="form-inline w-75" id="noSubmitForm">
          <input class="form-control mr-sm-2 rounded-0 rounded-start-1 border " type="search" placeholder="Search" aria-label="Search" id="search">
        </form>
        <div class="dropdown w-50 ">
            <button class="btn btn-primary dropdown-toggle rounded-0 rounded-end-1 " type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="Select search column">
              Select column
            </button>
            <div class="dropdown-menu" aria-labelledby="dropdownMenuButton" id="dropdownMenu">

            </div>

        </div>
  </div>

  </div>
<table class="table table-striped table-hover table-bordered w-100 m-0">
        <thead class="table-primary">
            <th scope="col">IP Address</th>
            <th scope="col">Number of Attempts</th>
            <th scope="col">Banned Until</th>
            <th scope="col">Last Seen</th>
            <th scope="col">Record clearing from DB (Time)</th>


            <th scope="col">&nbsp;</th>

        </thead>
        <tbody class="align-middle" id="userTableBody">
            <% ipRecords.forEach(ipRecord=> { %>
            <tr>
                <td><%= ipRecord.ip %></td>
                <td><%= ipRecord.attempts %></td>
                <td><%= ipRecord.bannedUntil ? ipRecord.bannedUntil.toLocaleString('hu-HU', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : 'Not banned' %></td>

                <td><%= ipRecord.lastAttempt ? ipRecord.lastAttempt.toLocaleString('hu-HU', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : 'Never' %></td>
                <td><%= ipRecord.lastAttempt ? new Date(ipRecord.lastAttempt.getTime() + (345600 * 1000)).toLocaleString('hu-HU', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }) : 'Not set' %></td>
                <td class="text-center" style="width: 5%;">

                    <button type="button" class="btn btn-danger btn-sm m-1" data-bs-toggle="modal"
                        data-bs-target="#deleteModal" data-ipid="<%= ipRecord._id %>"><i class="bi bi-ban"></i></button>
                </td>
            </tr>

            <% }); %>


        </tbody>
    </table>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel"
    aria-hidden="true" style="backdrop-filter: blur(5px);">
    <div class="modal-dialog" role="document">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Delete IP Record</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="deleteConfirmationText">Are you sure you want to delete this IP record?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteButton" data-deleteslug="User" data-beforeurl="/admin">Delete</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let IdToDelete = null;
    const deleteModal = document.getElementById('deleteModal');
    const confirmDeleteButton = document.getElementById('confirmDeleteButton');

    deleteModal?.addEventListener('show.bs.modal', event => {
        const button = event.relatedTarget;
        IdToDelete = button.getAttribute('data-ipid');
    });

    confirmDeleteButton?.addEventListener('click', () => {
        fetch('/admin/IpTables/delete/' + IdToDelete, {
            method: 'DELETE'
        }).then(response => {
            if (response.ok) {
                window.location.reload();
            } else {
                window.location.reload();
            }
        });
    });



});
</script>
