<div class="container my-4 border border-black border-1 border-opacity-10 rounded p-3  shadow bg-primary bg-opacity-10 " style="max-width: 80vh;">

<h1 class="text-center mb-3">Edit profile</h1>

<form action="/profile/<%= formID ? formID : 'noID' %>" method="POST">
    <div class="row justify-content-center g-3 m-auto">
        <div class="col-lg-10">

        </div>
        <div class="col-md-12">
            <div class="form-floating">
                <input type="text" class="form-control shadow-none" id="username" name="username" placeholder="Username"
                    autocomplete="off" value="<%= formData ? formData.username : "" %>">
                <label for="username" class="form-label">Username</label>
            </div>
        </div>
        <div class="col-md-12">
            <div class="form-floating">
                <input type="text" class="form-control shadow-none" id="fullname" name="fullname" placeholder="Fullname"
                    autocomplete="off" value="<%= formData ? formData.fullname : "" %>">
                <label for="fullname" class="form-label">Fullname</label>
            </div>

        <div class="border border-1 border-secondary border-opacity-25 p-2 rounded my-3">
        <div class="col-md-12 ms-3">
            <div class="form-check mb-2">
                <input type="checkbox" class="form-check-input shadow-none" id="changePasswordCheckbox" name="changePassword" autocomplete="off">
                <label for="changePasswordCheckbox" class="form-check-label">Change password?</label>
            </div>
        </div>

         <div class="col-md-12">
            <div class="form-floating">
                <input type="password" class="form-control shadow-none" id="password" name="password" placeholder="Password"
                    autocomplete="off" value="">
                <label for="password" class="form-label">Password (leave blank if not changing)</label>
            </div>
        </div>
        </div>
                 <div class="col-md-12">
            <div class="form-floating">
                <input type="text" class="form-control shadow-none" id="feiid" name="feiid" placeholder="feiid"
                    autocomplete="off" value="<%= formData ? formData.feiid : "" %>">
                <label for="feiid" class="form-label">FEI ID</label>
            </div>


            <div class="border border-1 border-secondary border-opacity-25 p-3 rounded my-4 position-relative">
    
                <p class="form-label position-absolute top-0 start-0 translate-middle-y ms-3 px-2   bg-opacity-10">
                    2FA
                </p>

                <% if (!formData.twoFactorEnabled) { %>
                <button type="button" id="enable2FA" class="btn btn-success w-100 shadow-none" data-bs-toggle="modal" data-bs-target="#2fapopup">
                    Enable 2FA
                </button>                
                 <% } else if (formData.twoFactorNeeded) { %>
                  <button type="button" id="reset2FA" class="btn btn-warning w-100 shadow-none" >Reset 2FA</button>
                    <% } else { %>
                  <button type="button"  id="disable2FA" class="btn btn-danger w-100 shadow-none" >Disable 2FA</button>
                <% } %> 

            </div>




            


                            <button type="submit" class="btn btn-primary mt-3 w-100">Update</button>

        </div>

        </div>

</form>



<div class="modal fade" id="2fapopup" tabindex="-1" aria-labelledby="2fapopupLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content border-0 shadow">
      <div class="modal-header">
        <h5 class="modal-title text-center" id="2fapopupLabel">2FA Setup</h5>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="2faBody">




      </div>
      <div class="modal-footer">
                <button type="button" class="btn btn-success" id="2faNextButton">Next</button>

      </div>
    </div>
  </div>
</div>



<script>
  const twofaModalEl = document.getElementById('2fapopup');
  const twofaModal = twofaModalEl ? new bootstrap.Modal(twofaModalEl) : null;

  function open2fa() {
    twofaModal?.show();
  }



function render2faStep() {
    if (twofaStep === 1) {
      twofabody.innerHTML = `
        <p>Scan the QR code below with your authenticator app:</p>
        <div class="text-center">
          <img src="/2fa/generate" alt="QR Code" class="img-fluid">
        </div>
        <p class="mt-3">Then enter the code generated by your app below:</p>
        <input type="text" id="twofaCodeInput" class="form-control shadow-none" placeholder="Enter 2FA code">
      `;
      twofaNextButton.textContent = 'Verify';
    } else if (twofaStep === 2) {
      const codeInput = document.getElementById('twofaCodeInput');
      const code = codeInput ? codeInput.value : '';
      fetch('/2fa/check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code })
      })
      .then(response => response.json())
      .then(data => {
        if (data.valid) {
            window.location.reload();
        } else {
            twofaModal.hide();
            ShowErrorToast('Failed to verify 2FA code. Please try again.');
        }
      }).catch(error => {
        twofaModal.hide();
        ShowErrorToast('An error occurred while verifying 2FA code.');
      });
    }
  }



  document.getElementById('enable2FA')?.addEventListener('click', function() {
    open2fa();
    render2faStep();
  });

  const twofabody = document.getElementById('2faBody');
  const twofaNextButton = document.getElementById('2faNextButton');
  let twofaStep = 1;

    twofaNextButton?.addEventListener('click', function() {
        if (twofaStep === 1) {
        twofaStep = 2;
        render2faStep();
        }
    });


    function disable2FA() {
        fetch('/2fa/disable', {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.reload();
            } else {
                ShowErrorToast('Failed to disable 2FA. Please try again.');
            }
        })
        .catch(error => {
            ShowErrorToast('An error occurred while disabling 2FA.');
        });
    }
    document.getElementById('disable2FA')?.addEventListener('click', function() {

        disable2FA();
    });
        document.getElementById('reset2FA')?.addEventListener('click', function() {

        disable2FA();
    });
  






</script>





<script>
    document.addEventListener("DOMContentLoaded", function() {
        document.getElementById("password").disabled = true;
        document.getElementById("changePasswordCheckbox").addEventListener("change", function() {
            document.getElementById("password").disabled = !this.checked;
        });
    });
</script>
