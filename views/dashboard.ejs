<div class="container my-4">
  <div class="p-3 mb-2 bg-primary bg-opacity-10 border border-1 border-black border-opacity-10 rounded text-center">
    <h2 class="m-0">PowerBird dashboard</h2>
  </div>
<div class="d-none d-md-block p-3 pb-1 mb-4 bg-primary bg-opacity-10 border border-black border-opacity-10 rounded-3 shadow-sm text-center">
  <div class="row g-3">
    <!-- 1. Stat -->
    <div class="col-6 col-md-3 border-end-md border-dark-subtle">
      <h6 class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.8rem;">Total Devices</h6>
      <p class="display-6 fw-bold text-primary mb-0" style="font-size: 1.8rem;"><%= dashboardStats.totalDevices %></p>
    </div>
    
    <!-- 2. Stat -->
    <div class="col-6 col-md-3 border-end-md border-dark-subtle">
      <h6 class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.8rem;">Open Defects</h6>
      <p class=" fw-bold text-success mb-0" style="font-size: 1.8rem;"><%= dashboardStats.totalOpenDefects %></p>
    </div>
    
    <!-- 3. Stat -->
    <div class="col-6 col-md-3 border-end-md border-dark-subtle">
      <h6 class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.8rem;">Late Checks</h6>
      <p class="display-6 fw-bold text-warning mb-0" style="font-size: 1.8rem;"><%= dashboardStats.LateChecks %></p>
    </div>
    
    <!-- 4. Stat -->
    <div class="col-6 col-md-3">
      <h6 class="text-uppercase text-muted fw-semibold mb-2" style="font-size: 0.8rem;">Late Battery</h6>
      <p class="display-6 fw-bold text-danger mb-0" style="font-size: 1.8rem;"><%= dashboardStats.LateBatteryChecks %></p>
    </div>
  </div>
</div>

  <div class="row g-4 text-center justify-content-center">
    <%
      // For example, define the card "database" here
      const allCards = cardsFromDB; // Assuming this is an array of objects

      // If there are no rolePermissions, use an empty array
      const permissons = typeof rolePermissons !== "undefined" ? rolePermissons : [];
    %>

    <% allCards.forEach(card => { %>
      <% if (Array.isArray(permissons) && permissons.includes(card.perm)) { %>
        <div class="col-md-3" style="min-width: 300px;">
          <div class="p-4 bg-<%= card.style %> bg-opacity-10 border border-1 border-black border-opacity-10 rounded h-100 d-flex flex-column justify-content-start">
            <div class="mb-3 h-50">
              <h5><%= card.title %></h5>
              <p class=""><%= card.text %></p>
            </div>
            <% for (let index = 0; index < card.label.length; index++) { %>
              <a href="<%= card.href[index] %>" class="btn btn-outline-<%= card.style %> w-100 mb-3"><%= card.label[index] %></a>
            <% } %>
          </div>
        </div>
      <% } %>
    <% }) %>
  </div>
</div>
